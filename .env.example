# =============================================================================
#  .env.example  –  Vorlage für Impressum & Datenschutz
# =============================================================================
#  Kopieren nach  .env  und ausfüllen, dann:
#      node scripts/gen-legal-config.mjs
#  WICHTIG:  .env  niemals committen!  ->  Eintrag in .gitignore
# =============================================================================

# ── Pflichtangaben (§ 5 DDG / Art. 4 Nr. 7 DSGVO) ────────────────────────────
LEGAL_NAME="Max Mustermann"
LEGAL_STREET="Musterstraße 1"
LEGAL_ZIP="64807"
LEGAL_CITY="Dieburg"
LEGAL_COUNTRY="Deutschland"
LEGAL_EMAIL="kontakt@example.de"

# ── Optional ─────────────────────────────────────────────────────────────────
LEGAL_PHONE=""                 # Telefon (empfohlen, nicht Pflicht)
LEGAL_RESPONSIBLE=""           # Verantwortlich n. § 18 Abs.2 MStV (leer = LEGAL_NAME)
LEGAL_USTID=""                 # USt-IdNr. – NUR falls tatsächlich vorhanden

# ── Hosting:  both | github | cloudflare | self ─────────────────────────────
LEGAL_HOSTING="both"

# Nur bei LEGAL_HOSTING="self":
LEGAL_SELFHOST_NAME=""         # z.B. "Hetzner Online GmbH"
LEGAL_SELFHOST_ADDRESS=""      # z.B. "Industriestr. 25, 91710 Gunzenhausen"
LEGAL_SELFHOST_COUNTRY="Deutschland"
LEGAL_SELFHOST_AV="true"       # AV-Vertrag nach Art. 28 DSGVO geschlossen?

# ── Externe Ressourcen (true = wird geladen und MUSS deklariert werden) ──────
# Auf "false" setzen, wenn du Fonts/Bibliotheken lokal mitlieferst (empfohlen).
LEGAL_GOOGLE_FONTS="true"      # fonts.googleapis.com / gstatic
LEGAL_CDNJS="true"             # cdnjs.cloudflare.com (jsPDF, JSZip …)
LEGAL_GITHUB_LINKS="true"      # externe Links zu github.com

# ── Aufsichtsbehörde (Default: Hessen) ───────────────────────────────────────
LEGAL_AUTHORITY="Der Hessische Beauftragte für Datenschutz und Informationsfreiheit"
LEGAL_AUTHORITY_URL="https://datenschutz.hessen.de"

# ── Stand (leer = aktuelles Datum beim Generieren) ───────────────────────────
LEGAL_LAST_UPDATED=""
